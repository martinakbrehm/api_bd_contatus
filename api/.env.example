# ================================================================
# api/.env.example
# Copie para api/.env e preencha com os valores reais.
# NUNCA versione o .env com credenciais reais.
# ================================================================

# ── BANCO DE DADOS (obrigatório) ──────────────────────────────
DB_HOST=seu-host-mysql.rds.amazonaws.com
DB_NAME=bd_contatus
DB_PORT=3306

# Usuário somente leitura + insert (consultas normais)
DB_USER=usuario_leitura
DB_PASSWORD=senha_segura_aqui

# Usuário com permissões DELETE/DROP (enriquecimento)
# Se não definido, usa DB_USER/DB_PASSWORD
DB_USER_ADMIN=usuario_admin
DB_PASSWORD_ADMIN=senha_admin_segura_aqui

# Timeouts de conexão (segundos) — big data: nunca omitir
DB_CONNECT_TIMEOUT=10
DB_READ_TIMEOUT=120
DB_WRITE_TIMEOUT=30

# ── JWT (obrigatório em produção) ─────────────────────────────
# Gere com: python3 -c "import secrets; print(secrets.token_hex(64))"
API_JWT_SECRET=SUBSTITUA_POR_TOKEN_HEX_64_GERADO_LOCALMENTE

# ── CORS (obrigatório em produção) ────────────────────────────
# Lista de origens separadas por vírgula
API_CORS_ORIGINS=https://seu-dominio.com

# ── HTTPS (obrigatório em produção) ──────────────────────────
API_ENFORCE_HTTPS=true

# ── API — configurações opcionais ─────────────────────────────
API_DEBUG=false
API_HOST=0.0.0.0
API_PORT=5001

# Timeouts de requisição por role (segundos)
API_REQUEST_TIMEOUT=60
API_REQUEST_TIMEOUT_ADMIN=180
API_REQUEST_TIMEOUT_USER=90
API_REQUEST_TIMEOUT_READONLY=30

# Timeout de query MySQL na camada da API
API_QUERY_TIMEOUT=120

# Parâmetros de busca em lotes
API_BATCH_SIZE_DB=5000
API_BATCH_MAX_ITER=20

# ── CACHE REDIS (opcional) ────────────────────────────────────
# Deixe vazio para desabilitar o cache (graceful degradation).
# Ex local:  redis://localhost:6379/0
# Ex prod:   redis://:senha@redis-host:6379/0
REDIS_URL=
CACHE_TTL_SECONDS=1800

# Nível de log (debug | info | warning | error)
LOG_LEVEL=info

# ── GUNICORN (produção) ───────────────────────────────────────
# Workers recomendado: (2 * CPU) + 1
GUNICORN_WORKERS=4
GUNICORN_LOG_LEVEL=info
